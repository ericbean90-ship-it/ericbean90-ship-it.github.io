---
// 카테고리별 글 목록
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllCategories, getPublishedPosts, toUrlSlug } from '../../lib/blog';

export async function getStaticPaths() {
  const categories = await getAllCategories();
  const posts = await getPublishedPosts();

  return categories.map(({ category }) => ({
    params: { category: toUrlSlug(category) },
    props: {
      category,
      posts: posts.filter((post) => post.data.category === category),
    },
  }));
}

const { category, posts } = Astro.props;
---

<BaseLayout title={`Category: ${category}`} description={`${category} 카테고리 글 목록`}>
  <section class="hero container">
    <h1 class="page-title">{category}</h1>
    <p class="page-lead">{posts.length}개의 글</p>
    <div class="filter-bar">
      <a href="/categories/">← 모든 카테고리</a>
      <a href="/blog/">Blog</a>
    </div>
  </section>

  <section class="section container">
    <div class="post-grid">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
