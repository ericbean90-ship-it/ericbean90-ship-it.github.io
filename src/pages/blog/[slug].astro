---
// 개별 블로그 글 페이지 — /blog/{slug}/
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  formatDate,
  getAdjacentPosts,
  getPublishedPosts,
  resolveSlug,
} from '../../lib/blog';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: resolveSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const posts = await getPublishedPosts();
const { prev, next } = getAdjacentPosts(posts, post);
---

<BaseLayout title={post.data.title} description={post.data.description ?? post.data.title}>
  <article class="container">
    <header class="post-header">
      <div class="post-header__meta">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        <a class="pill" href={`/categories/${post.data.category}/`}>
          {post.data.category}
        </a>
        {post.data.tags.map((tag) => (
          <a class="pill pill--muted" href={`/tags/${tag}/`}>
            #{tag}
          </a>
        ))}
      </div>
      <h1 class="page-title">{post.data.title}</h1>
      {post.data.description && <p class="page-lead">{post.data.description}</p>}
    </header>

    <div class="prose">
      <Content />
    </div>

    <nav class="post-nav" aria-label="글 이동">
      {prev ? (
        <a href={`/blog/${resolveSlug(prev)}/`}>
          <span>이전 글</span>
          {prev.data.title}
        </a>
      ) : (
        <span />
      )}
      {next ? (
        <a href={`/blog/${resolveSlug(next)}/`}>
          <span>다음 글</span>
          {next.data.title}
        </a>
      ) : (
        <span />
      )}
    </nav>
  </article>
</BaseLayout>
